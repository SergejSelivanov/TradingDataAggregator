{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss "
      }
    }
  },
  "ConnectionStrings": {
    "TradingData": "Data Source=./data/market-data.db"
  },
  "Ingestion": {
    "ChannelCapacity": 5000,
    "MaxBatchSize": 100,
    "FlushInterval": "00:00:01",
    "DeduplicationRetentionPeriod": "00:05:00"
  },
  "Reconnect": {
    "InitialDelay": "00:00:01",
    "MaxDelay": "00:00:15"
  }
}
